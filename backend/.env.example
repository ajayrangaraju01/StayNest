DJANGO_DEBUG=false
DJANGO_SECRET_KEY=replace-with-a-long-random-secret
DJANGO_ALLOWED_HOSTS=your-backend-domain.onrender.com
CORS_ALLOWED_ORIGINS=https://your-frontend-domain.vercel.app
CSRF_TRUSTED_ORIGINS=https://your-frontend-domain.vercel.app
DATABASE_URL=postgres://username:password@hostname:5432/dbname
DJANGO_EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
DJANGO_DEFAULT_FROM_EMAIL=StayNest <staynest.noreply@gmail.com>
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=staynest.noreply@gmail.com
EMAIL_HOST_PASSWORD=your-16-char-app-password
EMAIL_USE_TLS=true
DJANGO_SECURE_SSL_REDIRECT=true

ADMIN_PHONE=9999999999
ADMIN_EMAIL=admin@example.com
ADMIN_NAME=StayNest Admin
ADMIN_PASSWORD=replace-with-a-strong-password
